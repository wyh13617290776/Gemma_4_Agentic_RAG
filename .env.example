# .env 配置文件模板
# 使用方法: 复制此文件为 .env 并填入你实际的 Key

# --- Local Model Config ---
# 联网检索 API Keys
SERPER_API_KEY="your_serper_key_here"
TAVILY_API_KEY="your_tavily_key_here"
EXA_API_KEY="your_exa_key_here"

# 本地网络代理
PROXY_URL="http://127.0.0.1:7897"
NO_PROXY="localhost,127.0.0.1,::1"

# 运行模式
STREAMLIT_SERVER_PORT=8501
# --- Local Model Config ---

# --- Cloud LLM API Keys ---
SILICONFLOW_API_KEY="your_siliconflow_key_here"      # DeepSeek 密钥
DASHSCOPE_API_KEY="your_dashscope_key_here"        # 阿里通义千问 (Qwen) 密钥
# --- Cloud LLM API Keys ---